/* 全局样式 */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.btn-primary {
  background: #4A90D9;
  color: #fff;
  border-radius: 8rpx;
}

.btn-block {
  width: 100%;
}

.text-center {
  text-align: center;
}

.mt-20 {
  margin-top: 20rpx;
}
