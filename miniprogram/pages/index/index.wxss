.stats-row {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #4A90D9;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.question-card {
  margin-top: 20rpx;
}

.question-tag {
  display: inline-block;
  background: #e3f2fd;
  color: #4A90D9;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 32rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 30rpx;
}

.answer-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #4CAF50;
  margin-bottom: 20rpx;
}

.explain-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
}

.btn-group {
  margin-top: 40rpx;
}

.btn-secondary {
  background: #fff;
  color: #333;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
}

.btn-outline {
  background: transparent;
  color: #4A90D9;
  border: 1rpx solid #4A90D9;
  border-radius: 8rpx;
}
