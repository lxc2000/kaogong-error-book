<view class="container">
  <view class="card">
    <view class="form-group">
      <text class="label">题目内容 *</text>
      <textarea 
        class="textarea" 
        placeholder="请输入题目" 
        value="{{question}}" 
        bindinput="onQuestionInput"
        maxlength="500"
      />
    </view>

    <view class="form-group">
      <text class="label">答案 *</text>
      <input 
        class="input" 
        placeholder="如：A 或 ABC" 
        value="{{answer}}" 
        bindinput="onAnswerInput"
      />
    </view>

    <view class="form-group">
      <text class="label">知识点</text>
      <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker">
          {{subjects[subjectIndex] || '选择知识点'}}
        </view>
      </picker>
    </view>

    <view class="form-group">
      <text class="label">解析</text>
      <textarea 
        class="textarea" 
        placeholder="答案解析（可选）" 
        value="{{explain}}" 
        bindinput="onExplainInput"
        maxlength="200"
      />
    </view>

    <button class="btn-primary btn-block mt-20" bindtap="saveQuestion">
      💾 保存
    </button>
  </view>
</view>
